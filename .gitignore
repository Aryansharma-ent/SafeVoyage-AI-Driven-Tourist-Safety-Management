# Secrets and env files
.env
.env.*
!.env.example

# Keep env files in any subfolder out of git
**/.env
**/.env.*
!**/.env.example

# Common secret key/cert files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks

# Local config artifacts
*.local
*.secret

# Node/Python caches and dependencies
**/node_modules/
**/__pycache__/
*.pyc

# Build outputs
**/build/
**/dist/

# Logs
*.log
